{
  "mcpServers": {
    "arra-oracle": {
      "command": "bun",
      "args": ["run", "--cwd", "/root/Code/github.com/Soul-Brews-Studio/arra-oracle", "src/index.ts"],
      "env": {
        "ORACLE_DB_PATH": "/root/.oracle/oracle.db",
        "ORACLE_VECTOR_DB": "qdrant",
        "QDRANT_URL": "http://localhost:6333",
        "ORACLE_EMBEDDING_PROVIDER": "ollama",
        "OLLAMA_BASE_URL": "http://localhost:11434",
        "ORACLE_EMBEDDING_MODEL": "nomic-embed-text"
      }
    },
    "proxmox": {
      "command": "/root/maw-workspace/oracle-skills/proxmox-mcp/.venv/bin/python3",
      "args": ["-m", "proxmox_mcp.server"]
    }
  }
}
