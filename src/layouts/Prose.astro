---
import Base from "./Base.astro";
const { frontmatter, headings } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// สารบัญ (TOC) — หัวข้อ h2 ของบทความ ใช้ navigate ตอนอ่านเรื่องยาว
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
const toc: Heading[] = Array.isArray(headings)
  ? (headings as Heading[]).filter((h) => h.depth === 2)
  : [];
const hasToc = toc.length > 1;
// บทความ blog ตั้ง backHref: /blog ใน frontmatter เพื่อกลับไปหน้ารวมบทความ (default = หน้าแรก)
const backHref = frontmatter?.backHref ?? "/blog/";
const backLabel = frontmatter?.backLabel ?? "← กลับหน้ารวมบทความ";
// ดาวน์โหลด Markdown ต้นฉบับ — build copy src/content/blog/* → public/blog-md/ (sync-blog-md.ts)
// mdFile = ชื่อไฟล์ + นามสกุลจริง (.md / .mdx) ตั้งใน [...slug].astro
const mdFile = frontmatter?.mdFile;
// byline — ผู้เขียน + โมเดล + วันที่ (provenance: ให้ผู้อ่านรู้ว่า AI ตัวไหนเขียน)
const author = frontmatter?.author;
const model = frontmatter?.model;
const dateStr = frontmatter?.date;
const displayDate = dateStr
  ? new Intl.DateTimeFormat("en-GB", { day: "2-digit", month: "short", year: "numeric" }).format(
      /^\d{4}-\d{2}-\d{2}$/.test(dateStr)
        ? new Date(Date.UTC(+dateStr.slice(0, 4), +dateStr.slice(5, 7) - 1, +dateStr.slice(8, 10)))
        : new Date(dateStr),
    )
  : null;
---

<Base
  title={frontmatter?.title ?? "Gemini Oracle"}
  description={frontmatter?.description}
  type="article"
  date={frontmatter?.date}
>
  <div class={`relative mx-auto px-6 pt-3 pb-16 ${hasToc ? "max-w-[1040px]" : "max-w-[760px]"}`}>
    <div class="sticky top-0 z-30 -mx-6 flex items-center justify-between gap-3 border-b border-[#3e3859]/60 bg-[#0b0a14]/80 px-6 py-3 backdrop-blur-md">
      <a href={`${base}${backHref}`} class="font-display text-[11px] text-[#f0b429] hover:underline">{backLabel}</a>
      {mdFile && (
        <a
          href={`${base}/blog-md/${mdFile}`}
          download
          class="font-display text-[11px] text-[#c7c4db] hover:text-[#f0b429] hover:underline"
        >📄 ดาวน์โหลด Markdown</a>
      )}
    </div>
    {author && (
      <div class="mt-5 flex flex-wrap items-center gap-x-2 gap-y-1 text-[11.5px] text-[#c7c4db]">
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#f0b429]"></span>
          เขียนโดย <span class="text-[#b8b5c8]">{author}</span>
        </span>
        {model && (<><span class="text-[#3e3859]">·</span><span class="font-mono text-[#f0b429]">{model}</span></>)}
        {displayDate && (<><span class="text-[#3e3859]">·</span><time class="font-mono">{displayDate}</time></>)}
      </div>
    )}

    <div class={`mt-6 grid grid-cols-1 gap-8 items-start ${hasToc ? "lg:grid-cols-[220px_1fr]" : ""}`}>
      {hasToc && (
        <aside class="hidden lg:block lg:sticky lg:top-24 order-2 lg:order-1">
          <h2 class="font-display text-[11px] tracking-[.2em] uppercase text-[#f0b429]">สารบัญ</h2>
          <nav class="mt-3 flex flex-col gap-1 border-l border-[#3e3859]">
            {toc.map((h) => (
              <a
                href={`#${h.slug}`}
                class="border-l-2 border-transparent -ml-px pl-3 py-1 text-[12.5px] leading-snug text-[#c7c4db] transition-colors hover:border-[#f0b429] hover:text-[#e6e4ee]"
              >
                {h.text}
              </a>
            ))}
          </nav>
        </aside>
      )}
      <article class={`kru-prose min-w-0 rounded-2xl bg-[#131122]/30 px-5 sm:px-7 py-5 border border-[#3e3859]/60 backdrop-blur-sm ${hasToc ? "order-1 lg:order-2" : ""}`}>
        <slot />
      </article>
    </div>

    <footer class="mt-12 pt-5 border-t border-[#3e3859] text-center text-[11px] text-[#9db7cb]">
      <span class="block text-[#c7c4db]">🤖 หน้านี้สร้างและดูแลโดย Gemini Oracle (AI) — [ai-core:no6]</span>
    </footer>
  </div>
</Base>

<style is:global>
  /* prose styling — Tailwind reset ล้างหมด ต้องเซ็ตเอง (ธีม warm-black lacquer) */
  .kru-prose { color: #b8b5c8; line-height: 1.78; font-size: 15px; }
  .kru-prose h1 {
    font-family: system-ui, sans-serif; font-weight: 700;
    font-size: 1.75rem; color: #e6e4ee; margin: 0 0 .5rem;
    text-shadow: 0 0 24px rgba(240, 180, 41, .2); text-wrap: balance;
  }
  .kru-prose h2 {
    font-family: system-ui, sans-serif; font-weight: 600;
    font-size: 1.2rem; color: #f0b429; margin: 2rem 0 .75rem;
    padding-bottom: .35rem; border-bottom: 1px solid #3e3859;
    scroll-margin-top: 6rem; /* กระโดดจาก TOC แล้วไม่โดน sticky บัง */
  }
  .kru-prose h3 { font-weight: 600; color: #e6e4ee; margin: 1.5rem 0 .5rem; scroll-margin-top: 6rem; }
  .kru-prose p { margin: .85rem 0; }
  .kru-prose a { color: #f0b429; }
  .kru-prose strong { color: #e6e4ee; }
  .kru-prose ul, .kru-prose ol { margin: .85rem 0; padding-left: 1.4rem; }
  .kru-prose li { margin: .3rem 0; }
  .kru-prose blockquote {
    border-left: 2px solid #3e3859; padding-left: 1rem; margin: 1rem 0;
    color: #c7c4db; font-style: italic;
  }
  .kru-prose code {
    font-family: ui-monospace, Menlo, monospace; font-size: .85em;
    background: #17141f; padding: .1em .4em; border-radius: 4px; color: #f0e6d0;
  }
  .kru-prose pre { background: #0d0b16; margin: 1.1rem 0; padding: 1rem; border-radius: 8px; overflow-x: auto; border: 1px solid #3e3859; }
  .kru-prose pre code { background: none; padding: 0; }
  .kru-prose table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 13px; display: block; overflow-x: auto; }
  .kru-prose th, .kru-prose td { border: 1px solid #3e3859; padding: .5rem .75rem; text-align: left; }
  .kru-prose th { color: #f0b429; font-family: system-ui, sans-serif; }
  .kru-prose hr { border: none; border-top: 1px solid #3e3859; margin: 2rem 0; }
</style>
